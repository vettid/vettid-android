<?xml version="1.0" encoding="utf-8"?>
<!--
   VettID auto-backup / device-transfer rules.
   Pairs with android:allowBackup="false" + android:fullBackupContent="false"
   in the manifest, which already disables cloud backup outright. This file
   exists so the device-to-device transfer path (Android 12+, opt-out) is
   also locked down: no path under any data domain is allowed to migrate.
   See https://developer.android.com/guide/topics/data/autobackup#XMLSyntax
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="true">
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
